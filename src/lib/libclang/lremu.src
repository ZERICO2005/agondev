	.assume	adl=1

	.section	.text
	.global	__lremu

__lremu:
; I: EUHL=dividend, AUBC=divisor
; O: euhl=EUHL%AUBC

.if 0
	call	__ldvrmu
	ld	e, a
	push	de
	exx
	ld	a, e
	pop	de

	ret	z
	ei
	ret

.else
	push	ix
	push	iy

	call	__ldvrmu
	ld	e, a
	ld	a, iyh

	pop	iy
	pop	ix
